{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "linux-default",
      "displayName": "Linux Release (GTK4 + JACK)",
      "binaryDir": "${sourceDir}/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "OPIQO_TARGET_PLATFORM": "linux"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug (GTK4 + JACK)",
      "binaryDir": "${sourceDir}/build-linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "OPIQO_TARGET_PLATFORM": "linux"
      }
    },
    {
      "name": "linux-gtk3",
      "displayName": "Linux GTK3 (JACK)",
      "binaryDir": "${sourceDir}/build-linux-gtk3",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "OPIQO_TARGET_PLATFORM": "linux-gtk3"
      }
    },
    {
      "name": "linux-gtk3-debug",
      "displayName": "Linux GTK3 Debug (JACK)",
      "binaryDir": "${sourceDir}/build-linux-gtk3-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "OPIQO_TARGET_PLATFORM": "linux-gtk3"
      }
    },
    {
      "name": "linux-gtk2",
      "displayName": "Linux GTK2 (JACK)",
      "binaryDir": "${sourceDir}/build-linux-gtk2",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "OPIQO_TARGET_PLATFORM": "linux-gtk2"
      }
    },
    {
      "name": "linux-gtk2-debug",
      "displayName": "Linux GTK2 Debug (JACK)",
      "binaryDir": "${sourceDir}/build-linux-gtk2-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "OPIQO_TARGET_PLATFORM": "linux-gtk2"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-default",
      "configurePreset": "linux-default"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-gtk3",
      "configurePreset": "linux-gtk3"
    },
    {
      "name": "linux-gtk3-debug",
      "configurePreset": "linux-gtk3-debug"
    },
    {
      "name": "linux-gtk2",
      "configurePreset": "linux-gtk2"
    },
    {
      "name": "linux-gtk2-debug",
      "configurePreset": "linux-gtk2-debug"
    }
  ]
}
